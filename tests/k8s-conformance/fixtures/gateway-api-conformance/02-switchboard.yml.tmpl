---
apiVersion: gateway.networking.k8s.io/v1
kind: GatewayClass
metadata:
  name: switchboard
spec:
  controllerName: switchboard.rs/controller

---
apiVersion: v1
kind: Namespace
metadata:
  name: switchboard

---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: switchboard
  namespace: switchboard

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: switchboard-controller-config
  namespace: switchboard
data:
  controller.toml: |
    [info]
    name = "Switchboard Conformance"
    description = "Gateway API conformance test controller"

    [interface.http]
    bind = "[::]:8056"

    [resource.gateway.k8s]
    watch_all_namespaces = true

    [storage]
    type = "local"
    db_file = "/tmp/controller_storage.db"

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: switchboard
  namespace: switchboard
  labels:
    app: switchboard
spec:
  replicas: 1
  selector:
    matchLabels:
      app: switchboard
  template:
    metadata:
      labels:
        app: switchboard
    spec:
      serviceAccountName: switchboard
      containers:
        - name: switchboard
          image: __SWITCHBOARD_IMAGE__
          imagePullPolicy: Never
          env:
            - name: SBC_CONFIG_PATH
              value: /etc/switchboard/controller.toml
            - name: SBC_K8S
              value: "true"
          args:
            - --no-web-root
          ports:
            - name: admin
              containerPort: 8056
          volumeMounts:
            - name: controller-config
              mountPath: /etc/switchboard/controller.toml
              subPath: controller.toml
      volumes:
        - name: controller-config
          configMap:
            name: switchboard-controller-config

---
apiVersion: v1
kind: Service
metadata:
  name: switchboard
  namespace: switchboard
spec:
  type: ClusterIP
  selector:
    app: switchboard
  ports:
    - name: admin
      port: 8056
      targetPort: admin

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: switchboard-kernel-config
  namespace: switchboard
data:
  kernel.toml: |
    [info]
    name = "Switchboard Kernel"
    id = "conformance"
    description = "Kernel for Gateway API conformance"

    [controller.listen.http]
    host = "0.0.0.0"
    port = 8055

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sbk
  namespace: switchboard
  labels:
    app.kubernetes.io/name: sbk
    app.kubernetes.io/component: kernel
    app.kubernetes.io/part-of: switchboard.rs
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: sbk
      switchboard.rs/discovery: enabled
  template:
    metadata:
      labels:
        app.kubernetes.io/name: sbk
        app.kubernetes.io/component: kernel
        app.kubernetes.io/part-of: switchboard.rs
        switchboard.rs/discovery: enabled
    spec:
      containers:
        - name: sbk
          image: __SBK_IMAGE__
          imagePullPolicy: Never
          args:
            - /etc/switchboard/kernel.toml
          ports:
            - name: grpc
              containerPort: 8055
          volumeMounts:
            - name: kernel-config
              mountPath: /etc/switchboard/kernel.toml
              subPath: kernel.toml
          readinessProbe:
            tcpSocket:
              port: grpc
            initialDelaySeconds: 3
            periodSeconds: 5
          livenessProbe:
            tcpSocket:
              port: grpc
            initialDelaySeconds: 10
            periodSeconds: 10
      volumes:
        - name: kernel-config
          configMap:
            name: switchboard-kernel-config

---
apiVersion: v1
kind: Service
metadata:
  name: sbk
  namespace: switchboard
  labels:
    app.kubernetes.io/name: sbk
    app.kubernetes.io/component: kernel
    app.kubernetes.io/part-of: switchboard.rs
    switchboard.rs/discovery: enabled
spec:
  selector:
    app.kubernetes.io/name: sbk
    switchboard.rs/discovery: enabled
  ports:
    - name: grpc
      port: 8055
      targetPort: grpc
